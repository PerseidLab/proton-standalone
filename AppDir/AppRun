#!/bin/bash

# 1. Define Paths immediately (needed for --install/--uninstall)
HERE="$(dirname "$(readlink -f "${0}")")"
APPIMAGE_PATH="${APPIMAGE:-$(readlink -f "$0")}"
APPIMAGE_DIR="$(dirname "$APPIMAGE_PATH")"
APPS_DIR="$HOME/.local/share/applications"

# --- 2. Installation / Uninstallation Logic ---
# We check these BEFORE setting any default arguments
if [[ "$1" == "--install" ]]; then
    mkdir -p "$APPS_DIR"
    echo "Installing desktop shortcuts and MIME types..."

    cat <<EOF > "$APPS_DIR/run-proton.desktop"
[Desktop Entry]
Name=Proton AppImage Launcher
Exec="$APPIMAGE_PATH" %f
Icon=steam
Type=Application
Terminal=false
Categories=Utility
MimeType=application/x-ms-dos-executable;application/x-msi;application/x-msdownload;
EOF

    cat <<EOF > "$APPS_DIR/proton-explorer.desktop"
[Desktop Entry]
Name=Proton Explorer
Exec="$APPIMAGE_PATH" explorer
Icon=folder-wine
Type=Application
Terminal=false
Categories=Utility;
EOF

    cat <<EOF > "$APPS_DIR/proton-winecfg.desktop"
[Desktop Entry]
Name=Proton Winecfg
Exec="$APPIMAGE_PATH" winecfg
Icon=wine-winecfg
Type=Application
Terminal=false
Categories=Utility;
EOF

    cat <<EOF > "$APPS_DIR/proton-reboot.desktop"
[Desktop Entry]
Name=Proton Reboot (Kill)
Exec="$APPIMAGE_PATH" wineboot -k
Icon=system-reboot
Type=Application
Terminal=false
Categories=Utility;
EOF

    chmod +x "$APPS_DIR"/run-proton.desktop "$APPS_DIR"/proton-explorer.desktop "$APPS_DIR"/proton-winecfg.desktop "$APPS_DIR"/proton-reboot.desktop
    xdg-mime default run-proton.desktop application/x-ms-dos-executable
    xdg-mime default run-proton.desktop application/x-msi
    xdg-mime default run-proton.desktop application/x-msdownload
    update-desktop-database "$APPS_DIR" 2>/dev/null
    echo "Installation complete!"
    exit 0

elif [[ "$1" == "--uninstall" ]]; then
    echo "Removing shortcuts and resetting MIME types..."
    rm -f "$APPS_DIR/run-proton.desktop" "$APPS_DIR/proton-explorer.desktop" "$APPS_DIR/proton-winecfg.desktop" "$APPS_DIR/proton-reboot.desktop"
    xdg-mime uninstall "$APPS_DIR/run-proton.desktop" 2>/dev/null
    update-desktop-database "$APPS_DIR" 2>/dev/null
    echo "Uninstallation complete!"
    exit 0
fi

# --- 3. Default Argument Logic ---
# If NO argument is provided, default to "explorer"
# If an argument IS provided (like a file path or "winecfg"), we keep it.
if [ -z "$1" ]; then
    set -- "explorer"
fi

# 4. Define Prefix Path
PROTON_PREFIX="$APPIMAGE_DIR/protonprefix"

# 5. Internal Paths
INTERNAL_PROTON_BASE="$HERE/opt/GE-Proton"
INTERNAL_PROTON_SCRIPT="$INTERNAL_PROTON_BASE/proton"

# 6. Export Environment Variables
export WINEPREFIX="$PROTON_PREFIX/pfx"
export STEAM_COMPAT_DATA_PATH="$PROTON_PREFIX"
export STEAM_COMPAT_CLIENT_INSTALL_PATH="$HERE"
export PROTON_DISABLE_LSTEAMCLIENT=1
export PROTON_NO_STEAM=1
export PROTON_USE_WOW64=1
export SDL_JOYSTICK_HIDAPI=0
export SDL_HINT_JOYSTICK_HIDAPI=0

export GST_PLUGIN_SYSTEM_PATH_1_0="$HERE/opt/GE-Proton/files/lib/i386-linux-gnu/gstreamer-1.0/:$HERE/opt/GE-Proton/files/lib/x86_64-linux-gnu/gstreamer-1.0/"

export PROTON_NO_ESYNC=0
export WINEESYNC=1
export PROTON_NO_FSYNC=0
export WINEFSYNC=1
export WINESYNC=1

# 7. Execution Logic
if [ ! -d "$PROTON_PREFIX/pfx" ]; then
    echo "Creating prefix structure at $PROTON_PREFIX/pfx..."
    mkdir -p "$PROTON_PREFIX/pfx"
fi

if [ ! -f "$PROTON_PREFIX/tracked_files" ]; then
    echo "First run or prefix incomplete. Launching Proton..."

    if [ -f "$INTERNAL_PROTON_SCRIPT" ]; then
        python3 "$INTERNAL_PROTON_SCRIPT" run winecfg

        echo "Proton session closed. Launching Wine fallback..."
        WINE_WOW64="$INTERNAL_PROTON_BASE/files/bin-wow64/wine"
        WINE_64="$INTERNAL_PROTON_BASE/files/bin/wine64"
        WINE_STD="$INTERNAL_PROTON_BASE/files/bin/wine"

        if [ -f "$WINE_WOW64" ]; then
            exec "$WINE_WOW64" "$@"
        elif [ -f "$WINE_64" ]; then
            exec "$WINE_64" "$@"
        else
            exec "$WINE_STD" "$@"
        fi
    else
        echo "Error: Proton script not found at $INTERNAL_PROTON_SCRIPT"
        exit 1
    fi
else
    echo "Prefix exists. Launching Wine directly..."

    WINE_WOW64="$INTERNAL_PROTON_BASE/files/bin-wow64/wine"
    WINE_64="$INTERNAL_PROTON_BASE/files/bin/wine64"
    WINE_STD="$INTERNAL_PROTON_BASE/files/bin/wine"

    if [ -f "$WINE_WOW64" ]; then
        exec "$WINE_WOW64" "$@"
    elif [ -f "$WINE_64" ]; then
        exec "$WINE_64" "$@"
    else
        exec "$WINE_STD" "$@"
    fi
fi
