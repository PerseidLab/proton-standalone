#!/bin/bash

HERE="$(dirname "$(readlink -f "${0}")")"

APPIMAGE_PATH="$APPIMAGE"
if [ -z "$APPIMAGE_PATH" ]; then
    APPIMAGE_PATH="$(readlink -f "$0")"
fi

APPIMAGE_DIR="$(dirname "$APPIMAGE_PATH")"
APPS_DIR="$HOME/.local/share/applications"

if [[ "$1" == "--install" ]]; then
    mkdir -p "$APPS_DIR"
    echo "Installing desktop shortcuts and MIME types..."

    cat <<EOF > "$APPS_DIR/run-proton.desktop"
[Desktop Entry]
Name=Proton AppImage Launcher
Exec="$APPIMAGE_PATH" %f
Icon=steam
Type=Application
Terminal=false
Categories=Utility
MimeType=application/x-ms-dos-executable;application/x-msi;application/x-msdownload;
EOF

    cat <<EOF > "$APPS_DIR/proton-explorer.desktop"
[Desktop Entry]
Name=Proton Explorer
Exec="$APPIMAGE_PATH" explorer
Icon=folder-wine
Type=Application
Terminal=false
Categories=Utility;
EOF

    cat <<EOF > "$APPS_DIR/proton-winecfg.desktop"
[Desktop Entry]
Name=Proton Winecfg
Exec="$APPIMAGE_PATH" winecfg
Icon=wine-winecfg
Type=Application
Terminal=false
Categories=Utility;
EOF

    cat <<EOF > "$APPS_DIR/proton-reboot.desktop"
[Desktop Entry]
Name=Proton Reboot (Kill)
Exec="$APPIMAGE_PATH" wineboot -k
Icon=system-reboot
Type=Application
Terminal=false
Categories=Utility;
EOF

cat <<EOF > "$APPS_DIR/proton-cmd.desktop"
[Desktop Entry]
Name=Proton Command Prompt
Exec="$APPIMAGE_PATH" cmd
Icon=utilities-terminal
Type=Application
Terminal=false
Categories=Utility;
EOF

    cat <<EOF > "$APPS_DIR/proton-control.desktop"
[Desktop Entry]
Name=Proton Control Panel
Exec="$APPIMAGE_PATH" control
Icon=preferences-system
Type=Application
Terminal=false
Categories=Utility;
EOF

    chmod +x "$APPS_DIR"/*.desktop
    update-desktop-database "$APPS_DIR" 2>/dev/null
    echo "Installation complete!"
    exit 0

elif [[ "$1" == "--uninstall" ]]; then
    echo "Removing shortcuts..."
    rm -f "$APPS_DIR"/proton-*.desktop "$APPS_DIR/run-proton.desktop"
    update-desktop-database "$APPS_DIR" 2>/dev/null
    echo "Uninstallation complete!"
    exit 0
fi

if [ -z "$1" ]; then
    set -- "explorer"
fi

if [ -f "$1" ]; then
    REAL_PATH=$(readlink -f "$1")
    shift
    set -- "$REAL_PATH" "$@"
    echo "Resolved shortcut/link to: $REAL_PATH"
fi

PROTON_PREFIX="$APPIMAGE_DIR/protonprefix"
EXTRACT_DIR="$PROTON_PREFIX/appimage-root"
VERSION_FILE="$EXTRACT_DIR/.appimage_hash"

if [[ "$HERE" == /tmp/.mount_* ]]; then
    echo "Running from AppImage mount."

    mkdir -p "$PROTON_PREFIX"

    CURRENT_HASH="$(sha256sum "$APPIMAGE_PATH" | awk '{print $1}')"

    if [[ -f "$VERSION_FILE" ]]; then
        STORED_HASH="$(cat "$VERSION_FILE")"
    else
        STORED_HASH=""
    fi

    if [[ "$CURRENT_HASH" != "$STORED_HASH" ]]; then
        echo "Extracting AppImage into persistent prefix..."

        rm -rf "$EXTRACT_DIR"
        mkdir -p "$EXTRACT_DIR"

        (
            cd "$PROTON_PREFIX"
            "$APPIMAGE_PATH" --appimage-extract >/dev/null
            mv squashfs-root/* "$EXTRACT_DIR"/
            rm -rf squashfs-root
        )

        echo "$CURRENT_HASH" > "$VERSION_FILE"
        echo "Extraction complete."
    else
        echo "AppImage already extracted."
    fi

    echo "Relaunching from extracted AppRun..."
    exec "$EXTRACT_DIR/AppRun" "$@"
fi

INTERNAL_PROTON_BASE="$EXTRACT_DIR/opt/GE-Proton"
INTERNAL_PROTON_SCRIPT="$INTERNAL_PROTON_BASE/proton"

export WINEPREFIX="$PROTON_PREFIX/pfx"
export STEAM_COMPAT_DATA_PATH="$PROTON_PREFIX"
export STEAM_COMPAT_CLIENT_INSTALL_PATH="$HERE"
export WINEDLLPATH="$INTERNAL_PROTON_BASE/files/lib64/wine:$INTERNAL_PROTON_BASE/files/lib/wine"
export PROTON_DISABLE_LSTEAMCLIENT=1
export PROTON_NO_STEAM=1
export PROTON_USE_WOW64=1
export PROTON_MEDIA_USE_GST=1
export SDL_JOYSTICK_HIDAPI=0
export SDL_HINT_JOYSTICK_HIDAPI=0

export GST_PLUGIN_SYSTEM_PATH_1_0="$INTERNAL_PROTON_BASE/files/lib/i386-linux-gnu/gstreamer-1.0/:$INTERNAL_PROTON_BASE/files/lib/x86_64-linux-gnu/gstreamer-1.0/:$INTERNAL_PROTON_BASE/files/lib/gstreamer-1.0/:$INTERNAL_PROTON_BASE/files/lib64/gstreamer-1.0/:$HERE/gstreamer-1.0/x86_64/:$HERE/gstreamer-1.0/i386/"

mkdir -p "$PROTON_PREFIX/gstreamer-1.0/"
export WINE_GST_REGISTRY_DIR="$PROTON_PREFIX/gstreamer-1.0/"

mkdir -p "$PROTON_PREFIX/pfx"

PATHS=(
    "$HOME/.steam/steam/steamapps/common/SteamLinuxRuntime_sniper/"
    "$HOME/.var/app/com.valvesoftware.Steam/.steam/steam/steamapps/common/SteamLinuxRuntime_sniper/"
    "$HOME/.local/share/umu/"
)

SLR_ROOT=""
for path in "${PATHS[@]}"; do
    if [ -d "$path" ]; then
        SLR_ROOT="$path"
        break
    fi
done

echo "Launching Proton..."

if [ -f "$INTERNAL_PROTON_SCRIPT" ]; then
    if [ -n "$SLR_ROOT" ] && [ -f "$SLR_ROOT/run-in-sniper" ]; then
        exec "$SLR_ROOT/run-in-sniper" python3 "$INTERNAL_PROTON_SCRIPT" run "$@"
    else
        exec python3 "$INTERNAL_PROTON_SCRIPT" run "$@"
    fi
fi

WINE_WOW64="$INTERNAL_PROTON_BASE/files/bin-wow64/wine"
WINE_64="$INTERNAL_PROTON_BASE/files/bin/wine64"
WINE_STD="$INTERNAL_PROTON_BASE/files/bin/wine"

if [ -f "$WINE_WOW64" ]; then
    SELECTED_WINE="$WINE_WOW64"
elif [ -f "$WINE_64" ]; then
    SELECTED_WINE="$WINE_64"
else
    SELECTED_WINE="$WINE_STD"
fi

if [ -n "$SLR_ROOT" ] && [ -f "$SLR_ROOT/run-in-sniper" ]; then
    exec "$SLR_ROOT/run-in-sniper" "$SELECTED_WINE" "$@"
else
    exec "$SELECTED_WINE" "$@"
fi
