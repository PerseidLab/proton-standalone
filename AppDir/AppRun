#!/bin/bash

# --- 1. PATH DETECTION ---
if [[ -n "$APPDIR" ]]; then
    MOUNT_DIR="$APPDIR"
    APP_FILE_PATH="$APPIMAGE"
    BASE_DIR="$(dirname "$APPIMAGE")"
else
    MOUNT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    APP_FILE_PATH="$(realpath "$0")"
    BASE_DIR="$MOUNT_DIR"
fi

# Internal Paths
PROTON_DIR="$MOUNT_DIR/opt/GE-Proton"
WINE_BIN="$PROTON_DIR/files/bin/wine"
WINE_64="$PROTON_DIR/files/bin/wine64"

# External Paths
PREFIX_PATH="$BASE_DIR/sharedprotonprefix"
mkdir -p "$PREFIX_PATH"

# --- 2. INSTALLATION / UNINSTALLATION ---
if [[ "$1" == "--install" ]]; then
    DESKTOP_DIR="$HOME/.local/share/applications"
    mkdir -p "$DESKTOP_DIR"
    cat <<EOF > "$DESKTOP_DIR/proton-app.desktop"
[Desktop Entry]
Type=Application
Name=Proton App
Exec="$APP_FILE_PATH" %f
Icon=steam
Categories=Utility;
MimeType=application/x-ms-dos-executable;
EOF
    update-desktop-database "$DESKTOP_DIR"
    exit 0
fi

# --- 3. ARGUMENT HANDLING ---
if [ -z "$1" ]; then
    CMD="explorer"
elif [ -f "$1" ]; then
    ABS_EXE=$(realpath "$1")
    cd "$(dirname "$ABS_EXE")" || exit
    CMD="$ABS_EXE"
    shift
    EXTRA_ARGS=("$@")
else
    CMD="$1"
    shift
    EXTRA_ARGS=("$@")
fi

# --- 4. ENVIRONMENT CLEANUP (The Deck Fix) ---
# We must remove AppImage paths and point specifically to Proton's libs
unset LD_LIBRARY_PATH
unset PYTHONHOME
unset PYTHONPATH

# Required Proton/Wine Variables
export WINEPREFIX="$PREFIX_PATH"
export WINEDEBUG="-all"
export WINEDLLPATH="$PROTON_DIR/files/lib64/wine:$PROTON_DIR/files/lib/wine"
export LD_LIBRARY_PATH="$PROTON_DIR/files/lib64:$PROTON_DIR/files/lib:$LD_LIBRARY_PATH"

# Steam Deck Specifics
export WINE_NTSYNC=1
export DXVK_HUD=0

# --- 5. EXECUTION ---
# Check if we should use wine64 or wine
LAUNCHER="$WINE_64"
if [ ! -f "$LAUNCHER" ]; then LAUNCHER="$WINE_BIN"; fi

if [ ! -f "$LAUNCHER" ]; then
    echo "Error: Wine not found at $LAUNCHER"
    exit 1
fi

echo "Running: $CMD ${EXTRA_ARGS[*]}"
exec "$LAUNCHER" "$CMD" "${EXTRA_ARGS[@]}"
