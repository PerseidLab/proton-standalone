#!/bin/bash

# --- 1. PATH DETECTION ---
if [[ -n "$APPDIR" ]]; then
    MOUNT_DIR="$APPDIR"
    APP_FILE_PATH="$APPIMAGE"
    BASE_DIR="$(dirname "$APPIMAGE")"
else
    MOUNT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    APP_FILE_PATH="$(realpath "$0")"
    BASE_DIR="$MOUNT_DIR"
fi

PROTON_PATH="$MOUNT_DIR/opt/GE-Proton"
PREFIX_PATH="$BASE_DIR/sharedprotonprefix"
mkdir -p "$PREFIX_PATH"

# --- 2. INSTALLATION / UNINSTALLATION ---
if [[ "$1" == "--install" ]]; then
    DESKTOP_DIR="$HOME/.local/share/applications"
    mkdir -p "$DESKTOP_DIR"
    cat <<EOF > "$DESKTOP_DIR/proton-runner.desktop"
[Desktop Entry]
Type=Application
Name=Proton Runner
Exec="$APP_FILE_PATH" %f
Icon=steam
Categories=Utility;
MimeType=application/x-ms-dos-executable;
EOF
    update-desktop-database "$DESKTOP_DIR"
    echo "Installed."
    exit 0
fi

# --- 3. ARGUMENT CAPTURING (The Fix) ---
# We use a dedicated array to ensure we don't pass empty strings
FINAL_ARGS=()

if [ -z "$1" ]; then
    # Default behavior if launched with no args
    FINAL_ARGS=("explorer")
else
    # Check if first arg is a file
    if [ -f "$1" ]; then
        ABS_EXE=$(realpath "$1")
        cd "$(dirname "$ABS_EXE")" || exit
        shift
        # Rebuild the array with absolute path + remaining flags
        FINAL_ARGS=("$ABS_EXE" "$@")
    else
        # If it's just a command like 'explorer' or 'winecfg'
        FINAL_ARGS=("${@}")
    fi
fi

# --- 4. ENVIRONMENT SETUP ---
# Clear AppImage noise to prevent "Unit Test" warnings and library crashes
unset LD_LIBRARY_PATH
unset PYTHONHOME
unset PYTHONPATH

export STEAM_COMPAT_CLIENT_INSTALL_PATH="$HOME/.steam/steam"
export STEAM_COMPAT_DATA_PATH="$PREFIX_PATH"
export PROTON_NO_STEAM=1
export PROTON_NO_ESYNC=1
export PROTON_USE_WOW64=1

# GE-Proton specifically looks for these to avoid the "Unit Test" skip
export STAGING_SHARED_MEMORY=1
export PROTON_DEBUG=1

# --- 5. EXECUTION ---
if [ ! -f "$PROTON_PATH/proton" ]; then
    echo "Error: Proton not found at $PROTON_PATH/proton"
    exit 1
fi

# We use "run" as the first argument to the proton script, followed by our array
exec "$PROTON_PATH/proton" run "${FINAL_ARGS[@]}"
