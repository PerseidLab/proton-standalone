#!/bin/bash

# --- 0. CONFIGURATION & PATH DETECTION ---
DESKTOP_DIR="$HOME/.local/share/applications"
MAIN_DESKTOP="run-proton.desktop"
EXTRA_DESKTOPS=("proton-explorer.desktop" "proton-winecfg.desktop" "proton-reboot.desktop" "proton-terminal.desktop")

# Dynamic Path Detection
if [[ -n "$APPIMAGE" ]]; then
    APP_PATH="$APPIMAGE"
    PROTON_PATH="$APPDIR/opt/GE-Proton"
    # This changes the prefix to the folder containing the AppImage
    PREFIX_PATH="$(dirname "$APPIMAGE")/sharedprotonprefix"
else
    APP_PATH=$(realpath "$0")
    APP_DIR=$(dirname "$APP_PATH")
    PROTON_PATH="$APP_DIR/opt/GE-Proton"
    PREFIX_PATH="$APP_DIR/sharedprotonprefix"
fi

# --- STEAM RUNTIME DETECTION (Native & Flatpak) ---
RUNTIME_PATH="steamapps/common/SteamLinuxRuntime_sniper"
# 1. Check Native Steam path
RUNTIME_BASE="$HOME/.steam/steam/$RUNTIME_PATH"

# 2. Fallback to Flatpak Steam path if Native doesn't exist
if [ ! -d "$RUNTIME_BASE" ]; then
    FLATPAK_RUNTIME="$HOME/.var/app/com.valvesoftware.Steam/.local/share/Steam/$RUNTIME_PATH"
    if [ -d "$FLATPAK_RUNTIME" ]; then
        RUNTIME_BASE="$FLATPAK_RUNTIME"
        echo "Found Steam Linux Runtime in Flatpak path."
    fi
fi

mkdir -p "$PREFIX_PATH"

# --- 1. SELF-INSTALLATION / UNINSTALLATION LOGIC ---
if [[ "$1" == "--uninstall" ]]; then
    echo "Reverting installation..."
    rm -f "$DESKTOP_DIR/$MAIN_DESKTOP"
    for file in "${EXTRA_DESKTOPS[@]}"; do
        rm -f "$DESKTOP_DIR/$file"
    done
    update-desktop-database "$DESKTOP_DIR"
    exit 0
fi

# CHANGED: Removed the empty argument check from here so it doesn't trigger install by default
if [[ "$1" == "--install" ]]; then
    echo "Registering AppImage and creating shortcuts..."
    mkdir -p "$DESKTOP_DIR"

    cat <<EOF > "$DESKTOP_DIR/$MAIN_DESKTOP"
[Desktop Entry]
Type=Application
Name=Proton Runner (Portable)
Exec="$APP_PATH" %f
Icon=steam
Terminal=false
Categories=Utility;
MimeType=application/x-ms-dos-executable;application/x-msdownload;application/x-executable;
EOF

    # ... [Shortcuts logic for Explorer, Winecfg, etc would go here] ...

    chmod +x "$DESKTOP_DIR"/*.desktop
    xdg-mime default "$MAIN_DESKTOP" application/x-ms-dos-executable
    update-desktop-database "$DESKTOP_DIR"
    echo "Installation complete!"
    exit 0
fi

# --- 2. EXECUTION LOGIC ---
export STEAM_COMPAT_CLIENT_INSTALL_PATH="$HOME/.steam/steam"
export STEAM_COMPAT_DATA_PATH="$PREFIX_PATH"
export PROTON_VERB="run"
export PROTON_DISABLE_LSTEAMCLIENT=1
export PROTON_NO_STEAM=1
export PROTON_USE_WOW64=1
export PROTON_MEDIA_USE_GST=1
export SDL_JOYSTICK_HIDAPI=0
export SDL_HINT_JOYSTICK_HIDAPI=0

if [ ! -f "$PROTON_PATH/proton" ]; then
    echo "Error: Proton not found at $PROTON_PATH/proton"
    exit 1
fi

# Steam Runtime Integration
SNIPER_PLATFORM=$(ls -d "$RUNTIME_BASE"/sniper_platform_* 2>/dev/null | tail -n 1)
if [ -n "$SNIPER_PLATFORM" ]; then
    export PRESSURE_VESSEL_RUNTIME_ARCHIVE="$SNIPER_PLATFORM/files"
fi

# --- SMART PATH HANDLING ---
# If no arguments are passed, it now defaults to "explorer" and proceeds to execution
if [ -z "$1" ]; then
    SET_ARGS=("explorer")
elif [ -f "$1" ]; then
    EXE_PATH=$(realpath "$1")
    cd "$(dirname "$EXE_PATH")" || exit
    shift
    SET_ARGS=("$EXE_PATH" "$@")
else
    SET_ARGS=("${@}")
fi

# --- 3. EXECUTE ---
if [ -d "$RUNTIME_BASE" ] && [ -x "$RUNTIME_BASE/run-in-sniper" ]; then
    echo "Using Steam Linux Runtime (Sniper) at: $RUNTIME_BASE"
    exec "$RUNTIME_BASE/run-in-sniper" -- "$PROTON_PATH/proton" run "${SET_ARGS[@]}"
else
    echo "Warning: Steam Runtime not found in Native or Flatpak paths. Running Proton directly..."
    exec "$PROTON_PATH/proton" run "${SET_ARGS[@]}"
fi
