#!/bin/bash
set -e

# ==========================================
#    PORTABLE PROTON APPIMAGE RUNNER
# ==========================================

DESKTOP_DIR="$HOME/.local/share/applications"
MAIN_DESKTOP="portable-proton-runner.desktop"
EXTRA_DESKTOPS=("portable-proton-explorer.desktop" \
                "portable-proton-winecfg.desktop" \
                "portable-proton-reboot.desktop")

# ------------------------------------------
# PATH DETECTION (AppImage vs Local)
# ------------------------------------------
if [[ -n "$APPIMAGE" ]]; then
    # We are running inside an AppImage
    # 1. The .AppImage file location (where the prefix should live)
    APPIMAGE_FILE_DIR="$(dirname "$APPIMAGE")"
    PREFIX_PATH="$APPIMAGE_FILE_DIR/proton-prefix"

    # 2. The internal mount point (where GE-Proton is bundled)
    # $APPDIR is automatically set by the AppImage runtime
    PROTON_PATH="$APPDIR/opt/GE-Proton"
    APP_PATH="$APPIMAGE"
else
    # We are running as a loose script
    APP_PATH="$(realpath "$0")"
    APP_DIR="$(dirname "$APP_PATH")"
    PREFIX_PATH="$APP_DIR/proton-prefix"
    PROTON_PATH="$APP_DIR/opt/GE-Proton"
fi

mkdir -p "$PREFIX_PATH"

# ------------------------------------------
# INSTALL / UNINSTALL LOGIC
# ------------------------------------------

if [[ "$1" == "--install" ]]; then
    echo "Installing desktop shortcuts pointing to: $APP_PATH"
    mkdir -p "$DESKTOP_DIR"

    cat <<EOF > "$DESKTOP_DIR/$MAIN_DESKTOP"
[Desktop Entry]
Type=Application
Name=Portable Proton Runner
Comment=Run Windows EXEs via Proton
Exec="$APP_PATH" %f
Icon=run-proton
Terminal=false
Categories=Utility;
MimeType=application/x-ms-dos-executable;application/x-msdownload;
EOF

    cat <<EOF > "$DESKTOP_DIR/portable-proton-explorer.desktop"
[Desktop Entry]
Type=Application
Name=Portable Proton Explorer
Exec="$APP_PATH"
Icon=folder-wine
Terminal=false
Categories=Utility;
EOF

    cat <<EOF > "$DESKTOP_DIR/portable-proton-winecfg.desktop"
[Desktop Entry]
Type=Application
Name=Portable Proton Config
Exec="$APP_PATH" winecfg
Icon=wine-winecfg
Terminal=false
Categories=Utility;
EOF

    cat <<EOF > "$DESKTOP_DIR/portable-proton-reboot.desktop"
[Desktop Entry]
Type=Application
Name=Portable Proton Kill/Reboot
Exec="$APP_PATH" wineboot -k
Icon=system-reboot
Terminal=false
Categories=Utility;
EOF

    chmod +x "$DESKTOP_DIR"/portable-proton-*.desktop
    xdg-mime default "$MAIN_DESKTOP" application/x-ms-dos-executable
